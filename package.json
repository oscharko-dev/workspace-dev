{
  "name": "workspace-dev",
  "version": "1.0.0",
  "description": "Autonomous local workspace runtime for REST + deterministic Figma-to-code generation",
  "type": "module",
  "license": "MIT",
  "packageManager": "pnpm@10.30.3",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "bin": {
    "workspace-dev": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./contracts": {
      "import": {
        "types": "./dist/contracts/index.d.ts",
        "default": "./dist/contracts/index.js"
      },
      "require": {
        "types": "./dist/contracts/index.d.cts",
        "default": "./dist/contracts/index.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "template",
    "!template/**/node_modules",
    "!template/**/node_modules/**",
    "!template/**/*.test.ts",
    "!template/**/*.test.tsx",
    "README.md",
    "VERSIONING.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "THREAT_MODEL.md",
    "CODE_OF_CONDUCT.md",
    "COMPLIANCE.md",
    "ARCHITECTURE.md",
    "COMPATIBILITY.md",
    "SLA.md",
    "ESCROW.md",
    "ZERO_TELEMETRY.md",
    "SUPPORT.md",
    "CONTRACT_CHANGELOG.md",
    "PIPELINE.md"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts && node scripts/create-cjs-types.mjs && pnpm run ui:build",
    "typecheck": "tsc --noEmit && pnpm run ui:typecheck",
    "test": "pnpm run test:smoke:compile && pnpm run ui:build && tsx --test \"src/**/*.test.ts\" \"integration/**/*.test.ts\" && pnpm run test:scripts && pnpm run ui:test",
    "test:golden": "pnpm exec tsx --test src/parity/golden-fixtures.test.ts",
    "test:golden:update": "FIGMAPIPE_GOLDEN_APPROVE=true pnpm run test:golden",
    "test:customer-board": "pnpm exec tsx --test integration/customer-board-golden.helpers.test.ts integration/customer-board-golden.integration.test.ts",
    "test:customer-board:live": "pnpm exec tsx --test integration/customer-board-golden.live.test.ts",
    "test:customer-board:update": "FIGMAPIPE_CUSTOMER_BOARD_APPROVE=true pnpm exec tsx integration/customer-board-golden.update.ts",
    "test:smoke:compile": "node scripts/check-source-compile-smoke.mjs",
    "test:scripts": "node --test \"scripts/*.test.mjs\"",
    "test:dast-smoke": "pnpm exec tsx --test src/server/dast-smoke.e2e.test.ts",
    "test:ci": "pnpm run test",
    "test:flaky-retry": "node scripts/run-test-with-flaky-retry.mjs",
    "test:flaky-target": "pnpm run ui:test:e2e",
    "test:bdd": "tsx --test src/bdd-contract.test.ts",
    "test:property-based": "tsx --test src/mode-lock.fuzz.test.ts",
    "test:coverage": "c8 --all --src src --include \"src/**/*.ts\" --exclude \"src/**/*.test.ts\" --exclude \"src/isolated-server-entry.ts\" --exclude \"src/job-engine.ts\" --exclude \"src/job-engine/figma-source.ts\" --exclude \"src/job-engine/types.ts\" --exclude \"src/parity/types.ts\" --exclude \"src/parity/types-core.ts\" --exclude \"src/parity/types-edit-session.ts\" --exclude \"src/parity/types-job.ts\" --exclude \"src/parity/types-kpi.ts\" --exclude \"src/parity/types-mapping.ts\" --exclude \"src/parity/types-sync.ts\" --exclude \"src/parity/fixtures/golden/**/expected/src_theme_theme.ts\" --reporter=text-summary --reporter=lcov --reporter=json-summary --report-dir coverage tsx --test \"src/**/*.test.ts\" \"integration/**/*.test.ts\" && node scripts/check-coverage-thresholds.mjs",
    "test:mutation": "pnpm exec stryker run stryker.config.mjs",
    "benchmark:visual": "tsx integration/visual-benchmark.cli.ts",
    "composite:quality": "tsx scripts/compute-composite-quality.ts",
    "benchmark:visual:ab": "tsx integration/visual-benchmark-ab.cli.ts",
    "benchmark:visual:update-fixtures": "pnpm run benchmark:visual -- --update-fixtures",
    "benchmark:visual:update-references": "pnpm run benchmark:visual -- --update-references",
    "benchmark:visual:live": "pnpm run benchmark:visual -- --live",
    "benchmark:visual:update-baseline": "pnpm run benchmark:visual -- --update-baseline",
    "benchmark:visual:protocol": "tsx integration/visual-benchmark-measurement-protocol.ts",
    "benchmark:visual:report": "pnpm run benchmark:visual -- --ci --browsers chromium --storybook-component-catalog integration/fixtures/customer-board-golden/derived/storybook.component-visual-catalog.json --storybook-static-dir storybook-static/storybook-static && pnpm run benchmark:visual:protocol",
    "visual:baseline": "tsx integration/visual-baseline.cli.ts",
    "visual:audit": "tsx integration/visual-audit.cli.ts",
    "template:install": "pnpm --dir template/react-mui-app install --frozen-lockfile",
    "template:test": "pnpm --dir template/react-mui-app run test",
    "template:audit": "pnpm --dir template/react-mui-app audit --audit-level high",
    "template:signatures": "npm --prefix template/react-mui-app audit signatures",
    "ui:dev": "pnpm exec vite --config ui-src/vite.config.ts",
    "ui:build": "pnpm exec vite build --config ui-src/vite.config.ts",
    "ui:typecheck": "pnpm exec tsc --project ui-src/tsconfig.json --noEmit",
    "ui:lint": "pnpm exec eslint --no-config-lookup --max-warnings=0 --config ui-src/eslint.config.js \"ui-src/src/**/*.{ts,tsx}\"",
    "ui:test": "pnpm exec vitest run --config ui-src/vite.config.ts",
    "ui:test:coverage": "pnpm exec vitest run --config ui-src/vite.config.ts --coverage && UI_HOTSPOT_COVERAGE=1 pnpm exec vitest run --config ui-src/vite.config.ts --coverage",
    "ui:test:e2e": "node scripts/run-ui-e2e.mjs chromium",
    "ui:test:visual-live": "pnpm exec playwright test --config ui-src/playwright.config.ts --project=chromium ui-src/e2e/visual-parity.live.spec.ts",
    "ui:test:e2e:matrix": "node scripts/run-ui-e2e.mjs matrix",
    "ui:test:e2e:live": "node scripts/run-ui-e2e.mjs live",
    "lint:boundaries": "node scripts/check-boundary.mjs",
    "lint:ts-style": "eslint \"src/**/*.ts\" --max-warnings=0 --ignore-pattern \"src/**/*.test.ts\" --ignore-pattern \"src/parity/fixtures/golden/**\"",
    "lint:no-telemetry": "node scripts/check-no-telemetry.mjs",
    "lint:publint": "publint",
    "lint:types-publish": "attw --pack . --config-path .attw.json",
    "lint:size": "size-limit && node scripts/check-ui-worker-size.mjs",
    "verify:licenses": "node scripts/check-license-allowlist.mjs",
    "verify:lockfile-hosts": "node scripts/check-lockfile-host-allowlist.mjs",
    "verify:docs-template-stack": "node scripts/check-doc-template-stack.mjs",
    "verify:reproducible-build": "node scripts/verify-reproducible-build.mjs",
    "verify:airgap": "node scripts/verify-airgap-install.mjs",
    "verify:pack": "bash scripts/validate-pack.sh",
    "verify:fips": "node scripts/fips-smoke.mjs",
    "verify:sbom:parity": "node scripts/check-sbom-parity.mjs",
    "figma:export:visible": "node scripts/export-visible-figma-json.mjs",
    "storybook:evidence": "pnpm exec tsx src/storybook/generate-artifact.ts",
    "storybook:evidence:extract": "pnpm exec tsx src/storybook/generate-artifact.ts storybook-static/storybook-static reference/storybook",
    "storybook:public-extracts": "pnpm exec tsx src/storybook/generate-artifact.ts storybook-static/storybook-static reference/storybook",
    "perf:web:baseline": "pnpm --dir template/react-mui-app run perf:baseline",
    "perf:web:assert": "pnpm --dir template/react-mui-app run perf:assert",
    "sbom:cyclonedx": "node scripts/generate-cyclonedx.mjs artifacts/sbom/workspace-dev.cdx.json",
    "sbom:cyclonedx:template": "node scripts/generate-cyclonedx.mjs artifacts/sbom/figma-generated-app.cdx.json --package-root template/react-mui-app",
    "sbom:spdx": "node scripts/generate-spdx.mjs artifacts/sbom/workspace-dev.spdx.json",
    "sbom:spdx:template": "node scripts/generate-spdx.mjs artifacts/sbom/figma-generated-app.spdx.json --package-root template/react-mui-app",
    "release:changesets:publish": "node scripts/changesets-publish.mjs",
    "release:quality-gates": "pnpm run typecheck && pnpm run test && pnpm run template:install && pnpm run template:test && pnpm run test:golden && pnpm run ui:test:coverage && pnpm run test:coverage && pnpm run ui:test:e2e && pnpm run test:flaky-retry && pnpm run test:bdd && pnpm run test:property-based && pnpm run ui:lint && pnpm run lint:boundaries && pnpm run lint:ts-style && pnpm run lint:no-telemetry && pnpm run build && pnpm run lint:publint && pnpm run lint:types-publish && pnpm run lint:size && pnpm run verify:licenses && pnpm run verify:pack && pnpm run verify:lockfile-hosts && pnpm run verify:docs-template-stack && pnpm run verify:reproducible-build && pnpm run verify:fips && pnpm run sbom:cyclonedx && pnpm run sbom:cyclonedx:template && pnpm run sbom:spdx && pnpm run sbom:spdx:template && pnpm run verify:sbom:parity && pnpm run verify:airgap",
    "release:quality-gates:publish-lifecycle": "pnpm run typecheck && pnpm run test && pnpm run template:install && pnpm run template:test && pnpm run test:golden && pnpm run ui:test:coverage && pnpm run test:flaky-retry && pnpm run test:bdd && pnpm run test:property-based && pnpm run ui:lint && pnpm run lint:boundaries && pnpm run lint:ts-style && pnpm run lint:no-telemetry && pnpm run build && pnpm run lint:publint && pnpm run lint:size && pnpm run verify:licenses && pnpm run verify:pack && pnpm run verify:lockfile-hosts && pnpm run verify:docs-template-stack && pnpm run verify:reproducible-build && pnpm run verify:fips && pnpm run sbom:cyclonedx && pnpm run sbom:cyclonedx:template && pnpm run sbom:spdx && pnpm run sbom:spdx:template && pnpm run verify:sbom:parity && pnpm run verify:airgap",
    "prepublishOnly": "pnpm run release:quality-gates:publish-lifecycle"
  },
  "peerDependencies": {
    "typescript": ">=5.0.0"
  },
  "peerDependenciesMeta": {
    "typescript": {
      "optional": true
    }
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@cyclonedx/cyclonedx-npm": "^4.1.1",
    "@eslint/js": "^9.39.1",
    "@hookform/resolvers": "^5.2.2",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.1.0",
    "@stryker-mutator/core": "^9.6.0",
    "@stryker-mutator/tap-runner": "^9.6.0",
    "@stryker-mutator/typescript-checker": "^9.6.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.5.0",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "@typescript-eslint/parser": "^8.57.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.1",
    "c8": "^11.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "fast-check": "^4.6.0",
    "globals": "^17.5.0",
    "jsdom": "^29.0.1",
    "pixelmatch": "^7.1.0",
    "pngjs": "^7.0.0",
    "prettier": "^3.8.1",
    "publint": "^0.3.15",
    "react": "^19.2.4",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "shiki": "^4.0.2",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.1",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "engineStrict": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oscharko-dev/workspace-dev.git"
  },
  "homepage": "https://github.com/oscharko-dev/workspace-dev#readme",
  "bugs": {
    "url": "https://github.com/oscharko-dev/workspace-dev/issues"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/oscharko-dev"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "pnpm": {
    "overrides": {
      "flatted": "^3.4.2",
      "vitest>picomatch": "^4.0.4"
    }
  },
  "keywords": [
    "figma",
    "workspace",
    "local-dev",
    "mode-lock",
    "deterministic"
  ],
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "53 KB"
    },
    {
      "path": "dist/contracts/index.js",
      "limit": "5 KB"
    }
  ]
}
