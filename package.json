{
  "name": "workspace-dev",
  "version": "1.0.0",
  "description": "Autonomous local workspace runtime for REST + deterministic Figma-to-code generation",
  "type": "module",
  "license": "MIT",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "bin": {
    "workspace-dev": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./contracts": {
      "import": {
        "types": "./dist/contracts/index.d.ts",
        "default": "./dist/contracts/index.js"
      },
      "require": {
        "types": "./dist/contracts/index.d.cts",
        "default": "./dist/contracts/index.cjs"
      }
    }
  },
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "template",
    "!template/**/node_modules",
    "!template/**/node_modules/**",
    "README.md",
    "LICENSE",
    "CHANGELOG.md",
    "CONTRIBUTING.md",
    "SECURITY.md",
    "CODE_OF_CONDUCT.md",
    "COMPLIANCE.md",
    "ARCHITECTURE.md",
    "COMPATIBILITY.md",
    "SLA.md",
    "ESCROW.md",
    "ZERO_TELEMETRY.md",
    "SUPPORT.md",
    "CONTRACT_CHANGELOG.md",
    "REUSE.toml"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup --config tsup.config.ts && node scripts/create-cjs-types.mjs && pnpm run ui:build",
    "typecheck": "tsc --noEmit && pnpm run ui:typecheck",
    "test": "pnpm run test:smoke:compile && pnpm run ui:build && tsx --test \"src/**/*.test.ts\" \"integration/**/*.test.ts\" && pnpm run ui:test",
    "test:golden": "pnpm exec tsx --test src/parity/golden-fixtures.test.ts",
    "test:golden:update": "FIGMAPIPE_GOLDEN_APPROVE=true pnpm run test:golden",
    "test:smoke:compile": "node scripts/check-source-compile-smoke.mjs",
    "test:ci": "pnpm run test",
    "test:flaky-retry": "node scripts/run-test-with-flaky-retry.mjs",
    "test:bdd": "tsx --test src/bdd-contract.test.ts",
    "test:property-based": "tsx --test src/mode-lock.fuzz.test.ts",
    "test:coverage": "c8 --all --src src --include \"src/**/*.ts\" --exclude \"src/**/*.test.ts\" --exclude \"src/isolated-server-entry.ts\" --exclude \"src/parity/types.ts\" --reporter=text-summary --reporter=lcov --reporter=json-summary --report-dir coverage tsx --test \"src/**/*.test.ts\" \"integration/**/*.test.ts\" && node scripts/check-coverage-thresholds.mjs",
    "ui:dev": "pnpm exec vite --config ui-src/vite.config.ts",
    "ui:build": "pnpm exec vite build --config ui-src/vite.config.ts",
    "ui:typecheck": "pnpm exec tsc --project ui-src/tsconfig.json --noEmit",
    "ui:lint": "pnpm exec eslint --max-warnings=0 --config ui-src/.eslintrc.cjs \"ui-src/src/**/*.{ts,tsx}\"",
    "ui:test": "pnpm exec vitest run --config ui-src/vite.config.ts",
    "ui:test:e2e": "pnpm exec playwright test --config ui-src/playwright.config.ts",
    "lint:boundaries": "node scripts/check-boundary.mjs",
    "lint:ts-style": "eslint \"src/**/*.ts\" --max-warnings=0 --ignore-pattern \"src/**/*.test.ts\" --ignore-pattern \"src/parity/fixtures/golden/**\"",
    "lint:no-telemetry": "node scripts/check-no-telemetry.mjs",
    "lint:publint": "publint",
    "lint:types-publish": "attw --pack . --config-path .attw.json",
    "lint:size": "size-limit",
    "verify:licenses": "node scripts/check-license-allowlist.mjs",
    "verify:lockfile-hosts": "node scripts/check-lockfile-host-allowlist.mjs",
    "verify:docs-template-stack": "node scripts/check-doc-template-stack.mjs",
    "verify:reproducible-build": "node scripts/verify-reproducible-build.mjs",
    "verify:airgap": "node scripts/verify-airgap-install.mjs",
    "verify:pack": "bash scripts/validate-pack.sh",
    "verify:fips": "node scripts/fips-smoke.mjs",
    "figma:export:visible": "node scripts/export-visible-figma-json.mjs",
    "perf:web:baseline": "pnpm --dir template/react-mui-app run perf:baseline",
    "perf:web:assert": "pnpm --dir template/react-mui-app run perf:assert",
    "sbom:cyclonedx": "node scripts/generate-cyclonedx.mjs artifacts/sbom/workspace-dev.cdx.json",
    "sbom:spdx": "node scripts/generate-spdx.mjs artifacts/sbom/workspace-dev.spdx.json",
    "release:changesets:publish": "node scripts/changesets-publish.mjs",
    "release:quality-gates": "pnpm run typecheck && pnpm run test && pnpm run test:flaky-retry && pnpm run test:bdd && pnpm run test:property-based && pnpm run ui:lint && pnpm run lint:boundaries && pnpm run lint:ts-style && pnpm run lint:no-telemetry && pnpm run build && pnpm run lint:publint && pnpm run lint:types-publish && pnpm run lint:size && pnpm run verify:licenses && pnpm run verify:pack && pnpm run verify:lockfile-hosts && pnpm run verify:docs-template-stack && pnpm run verify:reproducible-build && pnpm run verify:fips && pnpm run sbom:cyclonedx && pnpm run sbom:spdx && pnpm run verify:airgap",
    "release:quality-gates:publish-lifecycle": "pnpm run typecheck && pnpm run test && pnpm run test:flaky-retry && pnpm run test:bdd && pnpm run test:property-based && pnpm run ui:lint && pnpm run lint:boundaries && pnpm run lint:ts-style && pnpm run lint:no-telemetry && pnpm run build && pnpm run lint:publint && pnpm run lint:size && pnpm run verify:licenses && pnpm run verify:pack && pnpm run verify:lockfile-hosts && pnpm run verify:docs-template-stack && pnpm run verify:reproducible-build && pnpm run verify:fips && pnpm run sbom:cyclonedx && pnpm run sbom:spdx && pnpm run verify:airgap",
    "prepublishOnly": "pnpm run release:quality-gates:publish-lifecycle"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.2",
    "@changesets/cli": "^2.30.0",
    "@cyclonedx/cyclonedx-npm": "^4.1.1",
    "@hookform/resolvers": "^5.2.2",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^11.2.0",
    "@tailwindcss/vite": "^4.2.1",
    "@tanstack/react-query": "^5.90.21",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.13.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.46.1",
    "@typescript-eslint/parser": "^8.46.1",
    "@vitejs/plugin-react": "^6.0.1",
    "c8": "^11.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "fast-check": "^4.6.0",
    "jsdom": "^28.1.0",
    "publint": "^0.3.15",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-hook-form": "^7.71.2",
    "react-router-dom": "^7.13.1",
    "size-limit": "^11.2.0",
    "tailwindcss": "^4.2.1",
    "tsup": "^8.5.0",
    "tsx": "^4.19.3",
    "typescript": "^5.9.2",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "zod": "^4.3.6"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "engineStrict": true,
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oscharko-dev/workspace-dev.git"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/",
    "provenance": true
  },
  "keywords": [
    "figma",
    "workspace",
    "local-dev",
    "mode-lock",
    "deterministic"
  ],
  "size-limit": [
    {
      "path": "dist/index.js",
      "limit": "53 KB"
    },
    {
      "path": "dist/contracts/index.js",
      "limit": "5 KB"
    }
  ]
}
