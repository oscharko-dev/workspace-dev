ignore-scripts=true
save-exact=true
# Dependency freshness gate: block packages published within 10080 min (7 days).
# Break-glass: reduce or remove locally to install a security patch inside the window.
# Do NOT commit a reduced or missing value — the CI gate enforces this setting.
minimum-release-age=10080
# Per-package break-glass for HIGH-severity security advisories. fast-uri 3.1.2
# (released 2026-05-05) patches GHSA-q3j6-qgpj-74h6 (path traversal) AND
# GHSA-v39h-62p7-jpjc (host confusion via percent-encoded authority
# delimiters). 3.1.1 patches only the first and is itself vulnerable to the
# second, so the original PR pin to 3.1.1 was rejected by the dependency-
# review gate. Remove this line once 3.1.2 is older than 7 days.
minimum-release-age-exclude[]=fast-uri
